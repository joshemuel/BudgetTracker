POSTGRES_USER=budget
POSTGRES_PASSWORD=budget
POSTGRES_DB=budget
POSTGRES_PORT=5432

BACKEND_PORT=8000

APP_SECRET=replace-with-a-long-random-string

TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
# Random string; echoed by Telegram in X-Telegram-Bot-Api-Secret-Token and
# verified on the webhook. Set, then re-register the webhook (admin only).
TELEGRAM_WEBHOOK_SECRET=

# Google OAuth — create an OAuth 2.0 Client ID (type: Web application) in the
# Google Cloud Console. Authorized redirect URI must match GOOGLE_REDIRECT_URI.
# Prod: https://budgettracker.ddns.net/api/auth/google/callback
# Dev:  http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# Extra ID-token audiences to accept besides GOOGLE_CLIENT_ID, comma-separated.
# Leave empty for web-only. When a native Play Store app ships, add its
# Android/iOS OAuth client id here so its tokens verify (no code change).
GOOGLE_ALLOWED_AUDIENCES=
# Where to send the browser after the OAuth callback. Leave empty in prod
# (same-origin "/"); in dev set to the Vite origin, e.g. http://localhost:5173
FRONTEND_BASE_URL=

# Google Sheets auto-sync. Register this as a SECOND authorized redirect URI on
# the SAME OAuth client above, and add the (non-sensitive) drive.file scope to
# the consent screen. Empty disables the feature. Resolves to backend /sheets/callback.
# Prod: https://budgettracker.ddns.net/api/sheets/callback
# Dev:  http://localhost:8000/sheets/callback
GOOGLE_SHEETS_REDIRECT_URI=
# Fernet key encrypting stored Google refresh tokens at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty to derive a key from APP_SECRET (fine for single-host self-hosting).
GOOGLE_TOKEN_ENC_KEY=

# OpenRouter (https://openrouter.ai) — single key for all LLM calls.
OPENROUTER_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
# Text path (intent classify, extraction, queries, daily summary).
LLM_MODEL=deepseek/deepseek-v4-flash
LLM_LOG_MODEL=deepseek/deepseek-v4-flash
LLM_QUERY_MODEL=deepseek/deepseek-v4-flash
# Media path — audio (voice notes) and OCR (future image logging).
LLM_MEDIA_MODEL=google/gemini-2.5-flash-lite
LLM_OCR_MODEL=google/gemini-2.5-flash-lite

TZ=Asia/Jakarta
