POSTGRES_USER=budget
POSTGRES_PASSWORD=budget
POSTGRES_DB=budget
POSTGRES_PORT=5432

BACKEND_PORT=8000

APP_SECRET=replace-with-a-long-random-string

TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
# Random string; echoed by Telegram in X-Telegram-Bot-Api-Secret-Token and
# verified on the webhook. Set, then re-register the webhook (admin only).
TELEGRAM_WEBHOOK_SECRET=

# Google OAuth — create an OAuth 2.0 Client ID (type: Web application) in the
# Google Cloud Console. Authorized redirect URI must match GOOGLE_REDIRECT_URI.
# Prod: https://budgettracker.ddns.net/api/auth/google/callback
# Dev:  http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# Extra ID-token audiences to accept besides GOOGLE_CLIENT_ID, comma-separated.
# Leave empty for web-only. When a native Play Store app ships, add its
# Android/iOS OAuth client id here so its tokens verify (no code change).
GOOGLE_ALLOWED_AUDIENCES=
# Where to send the browser after the OAuth callback. Leave empty in prod
# (same-origin "/"); in dev set to the Vite origin, e.g. http://localhost:5173
FRONTEND_BASE_URL=

GEMINI_API_KEY=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_MODEL=gemini-2.5-flash-lite
LLM_QUERY_MODEL=gemini-2.5-flash

TZ=Asia/Jakarta
